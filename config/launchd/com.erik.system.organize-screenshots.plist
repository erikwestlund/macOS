<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.erik.system.organize-screenshots</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/erik/.config/macos/organize-screenshots.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>45</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/organize-screenshots.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/organize-screenshots.err.log</string>
</dict>
</plist>
