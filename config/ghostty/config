theme = TokyoNight Storm
window-padding-x = 14
window-padding-y = 12
window-padding-balance = true
copy-on-select = true

# Split management
keybind = super+d=new_split:down
keybind = super+shift+d=new_split:right
keybind = ctrl+super+h=goto_split:left
keybind = ctrl+super+j=goto_split:down
keybind = ctrl+super+k=goto_split:up
keybind = ctrl+super+l=goto_split:right
keybind = ctrl+super+w=close_surface
keybind = ctrl+super+enter=toggle_split_zoom
