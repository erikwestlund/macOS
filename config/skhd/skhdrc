#!/usr/bin/env sh

# Focus windows in the current BSP tree.
alt - h : /opt/homebrew/bin/yabai -m window --focus west || /opt/homebrew/bin/yabai -m window --focus east
alt - j : /opt/homebrew/bin/yabai -m window --focus south || /opt/homebrew/bin/yabai -m window --focus north
alt - k : /opt/homebrew/bin/yabai -m window --focus north || /opt/homebrew/bin/yabai -m window --focus south
alt - l : /opt/homebrew/bin/yabai -m window --focus east || /opt/homebrew/bin/yabai -m window --focus west
ctrl - h : /opt/homebrew/bin/yabai -m window --focus west || /opt/homebrew/bin/yabai -m window --focus east
ctrl - j : /opt/homebrew/bin/yabai -m window --focus south || /opt/homebrew/bin/yabai -m window --focus north
ctrl - k : /opt/homebrew/bin/yabai -m window --focus north || /opt/homebrew/bin/yabai -m window --focus south
ctrl - l : /opt/homebrew/bin/yabai -m window --focus east || /opt/homebrew/bin/yabai -m window --focus west

# Move windows around inside the current BSP tree.
shift + alt - h : /opt/homebrew/bin/yabai -m window --warp west
shift + alt - j : /opt/homebrew/bin/yabai -m window --warp south
shift + cmd - h : /opt/homebrew/bin/yabai -m window --warp west
shift + cmd - j : /opt/homebrew/bin/yabai -m window --warp south

# Focus or launch Ivanti Secure Access.
ctrl + alt - j : ~/.config/yabai/focus-or-launch-ivanti.sh

# Move windows around inside the current BSP tree.
shift + alt - k : /opt/homebrew/bin/yabai -m window --warp north
shift + alt - l : /opt/homebrew/bin/yabai -m window --warp east
shift + cmd - k : /opt/homebrew/bin/yabai -m window --warp north
shift + cmd - l : /opt/homebrew/bin/yabai -m window --warp east

# Focus or launch Tailscale.
ctrl + alt - v : ~/.config/yabai/focus-or-launch-tailscale.sh

# Focus or launch Messages.
shift + ctrl - m : ~/.config/yabai/focus-or-launch-messages.sh

# Restore constant workspace layouts.
ctrl + alt - 0 : ~/.config/yabai/restore-workspace-layout.sh ws10
ctrl + alt - 0x1B : ~/.config/yabai/restore-workspace-layout.sh ws11
ctrl + alt - y : ~/.config/yabai/restore-workspace-layout.sh scratch

# Snap the focused tiled window to a half-screen side.
shift + alt + cmd - h : ~/.config/yabai/snap-window.sh west
shift + alt + cmd - j : ~/.config/yabai/snap-window.sh south
shift + alt + cmd - k : ~/.config/yabai/snap-window.sh north
shift + alt + cmd - l : ~/.config/yabai/snap-window.sh east

# Resize the focused window.
shift + alt - 0x2B : /opt/homebrew/bin/yabai -m window --resize left:-80:0 || /opt/homebrew/bin/yabai -m window --resize right:80:0
shift + alt - 0x2F : /opt/homebrew/bin/yabai -m window --resize left:80:0 || /opt/homebrew/bin/yabai -m window --resize right:-80:0
shift + cmd - 0x2B : /opt/homebrew/bin/yabai -m window --resize left:-80:0 || /opt/homebrew/bin/yabai -m window --resize right:80:0
shift + cmd - 0x2F : /opt/homebrew/bin/yabai -m window --resize left:80:0 || /opt/homebrew/bin/yabai -m window --resize right:-80:0
shift + alt + cmd - 0x2B : /opt/homebrew/bin/yabai -m window --resize top:0:80 || /opt/homebrew/bin/yabai -m window --resize bottom:0:-80
shift + alt + cmd - 0x2F : /opt/homebrew/bin/yabai -m window --resize top:0:-80 || /opt/homebrew/bin/yabai -m window --resize bottom:0:80

# Toggle the focused window between tiled and floating.
alt + cmd - n : /opt/homebrew/bin/yabai -m window --toggle float --grid 4:4:1:1:2:2

# Toggle or clear always-on-top for the focused window.
alt - f : /opt/homebrew/bin/yabai -m window --toggle topmost
shift + alt - f : /opt/homebrew/bin/yabai -m window --layer normal

# Toggle the focused window into Omarchy-style focus mode.
alt + cmd - m : ~/.config/yabai/focus-mode.sh

# Toggle the system monitor popup.
shift + alt - m : ~/.config/sketchybar/plugins/system_monitor.sh popup

# Always open a new Ghostty window on the current workspace.
alt - return : ~/.config/yabai/open-new-ghostty.sh

# Open a new Ghostty window running btop.
shift + cmd - m : ~/.bin/ghostty-btop

# Open a new Ghostty window running lazydocker.
ctrl + shift - d : ~/.bin/ghostty-new-window "lazydocker"

# Focus or launch Apple Music.
shift + alt + cmd - m : ~/.config/yabai/focus-or-launch-music.sh

# Open a new Finder window.
shift + cmd - f : ~/.bin/finder-new-window

# Open a new Finder window to Downloads.
alt + cmd - d : ~/.bin/finder-downloads-window

# Focus or launch Fastmail.
shift + cmd - e : ~/.config/yabai/focus-or-launch-fastmail.sh

# Focus or launch Morgen.
shift + alt - c : ~/.config/yabai/focus-or-launch-morgen.sh

# Focus or launch Obsidian.
alt + cmd - o : ~/.config/yabai/focus-or-launch-obsidian.sh

# Temporarily disabled to allow 1Password's native global shortcut.
# shift + cmd - p : ~/.config/yabai/focus-or-launch-1password.sh

# Focus or launch Slack.
shift + alt - s : ~/.bin/focus-or-launch-slack

# Focus or launch Spotify.
shift + cmd - s : ~/.config/yabai/focus-or-launch-spotify.sh

# Open the hotkey cheatsheet in Ghostty.
alt + cmd - h : ~/.bin/ghostty-cheatsheet

# Open Working Memory in a new floating Zed window.
alt + cmd - k : ~/.config/yabai/open-working-memory.sh

# Always open a new Claude web app window on the current workspace.
shift + cmd - i : ~/.config/yabai/open-new-claude.sh

# Always open a new ChatGPT web app window on the current workspace.
shift + cmd - a : ~/.config/yabai/open-new-chatgpt.sh

# Always open a new Google Chrome window on the current workspace.
shift + cmd - b : ~/.config/yabai/open-new-chrome.sh

# Focus or launch YouTube.
shift + cmd - y : ~/.config/yabai/focus-or-launch-youtube.sh

# Always open a new TablePlus window.
shift + cmd - u : ~/.config/yabai/open-new-tableplus.sh

# Focus or launch Microsoft Outlook.
shift + cmd - o : ~/.config/yabai/focus-or-launch-outlook.sh

# Focus or launch Microsoft Teams.
shift + cmd - t : ~/.config/yabai/focus-or-launch-teams.sh

# Focus or launch Zoom.
shift + cmd - z : ~/.config/yabai/focus-or-launch-zoom.sh

# Toggle the tmux popup.
shift + alt - t : NAME=tmux ~/.config/sketchybar/plugins/tmux.sh popup

# Toggle the workspace apps popup.
shift + alt - w : NAME=workspace_apps ~/.config/sketchybar/plugins/workspace_apps.sh toggle

# Open the Weather app.
alt + cmd - w : open -a Weather

# Focus absolute previous/next spaces with wraparound.
# Keep plain option+arrow free for normal macOS word navigation.
ctrl + alt - left : ~/.config/yabai/focus-absolute-space.sh prev
ctrl + alt - right : ~/.config/yabai/focus-absolute-space.sh next

# Focus previous/next occupied spaces.
alt - 0x21 : ~/.config/yabai/focus-active-space.sh prev
alt - 0x1E : ~/.config/yabai/focus-active-space.sh next
cmd - 0x21 : ~/.config/yabai/focus-active-space.sh prev
cmd - 0x1E : ~/.config/yabai/focus-active-space.sh next

# Toggle a hidden scratch workspace on space 13.
alt - 0x10 : ~/.config/yabai/toggle-scratch-space.sh

# Send the focused window to the scratch workspace.
shift + alt - 0x10 : ~/.config/yabai/send-to-scratch-space.sh

# Toggle a hidden utility workspace on space 14.
alt - 0x32 : ~/.config/yabai/toggle-utility-space.sh

# Send the focused window to the utility workspace.
shift + alt - 0x32 : ~/.config/yabai/send-to-utility-space.sh

# Focus workspaces 1-12 with Option+1-0,-,=
alt - 1 : ~/.config/yabai/focus-space.sh 1
alt - 2 : ~/.config/yabai/focus-space.sh 2
alt - 3 : ~/.config/yabai/focus-space.sh 3
alt - 4 : ~/.config/yabai/focus-space.sh 4
alt - 5 : ~/.config/yabai/focus-space.sh 5
alt - 6 : ~/.config/yabai/focus-space.sh 6
alt - 7 : ~/.config/yabai/focus-space.sh 7
alt - 8 : ~/.config/yabai/focus-space.sh 8
alt - 9 : ~/.config/yabai/focus-space.sh 9
alt - 0 : ~/.config/yabai/focus-space.sh 10
alt - 0x1B : ~/.config/yabai/focus-space.sh 11
alt - 0x18 : ~/.config/yabai/focus-space.sh 12
ctrl - 1 : ~/.config/yabai/focus-space.sh 1
ctrl - 2 : ~/.config/yabai/focus-space.sh 2
ctrl - 3 : ~/.config/yabai/focus-space.sh 3
ctrl - 4 : ~/.config/yabai/focus-space.sh 4
ctrl - 5 : ~/.config/yabai/focus-space.sh 5
ctrl - 6 : ~/.config/yabai/focus-space.sh 6
ctrl - 7 : ~/.config/yabai/focus-space.sh 7
ctrl - 8 : ~/.config/yabai/focus-space.sh 8
ctrl - 9 : ~/.config/yabai/focus-space.sh 9
ctrl - 0 : ~/.config/yabai/focus-space.sh 10
ctrl - 0x1B : ~/.config/yabai/focus-space.sh 11
ctrl - 0x18 : ~/.config/yabai/focus-space.sh 12

# Send the focused window to workspaces 1-12 and follow it.
shift + alt - 1 : ~/.config/yabai/send-window-to-space-and-follow.sh 1
shift + alt - 2 : ~/.config/yabai/send-window-to-space-and-follow.sh 2
shift + alt - 3 : ~/.config/yabai/send-window-to-space-and-follow.sh 3
shift + alt - 4 : ~/.config/yabai/send-window-to-space-and-follow.sh 4
shift + alt - 5 : ~/.config/yabai/send-window-to-space-and-follow.sh 5
shift + alt - 6 : ~/.config/yabai/send-window-to-space-and-follow.sh 6
shift + alt - 7 : ~/.config/yabai/send-window-to-space-and-follow.sh 7
shift + alt - 8 : ~/.config/yabai/send-window-to-space-and-follow.sh 8
shift + alt - 9 : ~/.config/yabai/send-window-to-space-and-follow.sh 9
shift + alt - 0 : ~/.config/yabai/send-window-to-space-and-follow.sh 10
shift + alt - 0x1B : ~/.config/yabai/send-window-to-space-and-follow.sh 11
shift + alt - 0x18 : ~/.config/yabai/send-window-to-space-and-follow.sh 12
shift + cmd - 1 : ~/.config/yabai/send-window-to-space-and-follow.sh 1
shift + cmd - 2 : ~/.config/yabai/send-window-to-space-and-follow.sh 2
shift + cmd - 3 : ~/.config/yabai/send-window-to-space-and-follow.sh 3
shift + cmd - 4 : ~/.config/yabai/send-window-to-space-and-follow.sh 4
shift + cmd - 5 : ~/.config/yabai/send-window-to-space-and-follow.sh 5
shift + cmd - 6 : ~/.config/yabai/send-window-to-space-and-follow.sh 6
shift + cmd - 7 : ~/.config/yabai/send-window-to-space-and-follow.sh 7
shift + cmd - 8 : ~/.config/yabai/send-window-to-space-and-follow.sh 8
shift + cmd - 9 : ~/.config/yabai/send-window-to-space-and-follow.sh 9
shift + cmd - 0 : ~/.config/yabai/send-window-to-space-and-follow.sh 10
shift + cmd - 0x1B : ~/.config/yabai/send-window-to-space-and-follow.sh 11
shift + cmd - 0x18 : ~/.config/yabai/send-window-to-space-and-follow.sh 12

# Send the focused window to workspaces 1-12 without switching.
ctrl + shift + alt - 1 : /opt/homebrew/bin/yabai -m window --space 1
ctrl + shift + alt - 2 : /opt/homebrew/bin/yabai -m window --space 2
ctrl + shift + alt - 3 : /opt/homebrew/bin/yabai -m window --space 3
ctrl + shift + alt - 4 : /opt/homebrew/bin/yabai -m window --space 4
ctrl + shift + alt - 5 : /opt/homebrew/bin/yabai -m window --space 5
ctrl + shift + alt - 6 : /opt/homebrew/bin/yabai -m window --space 6
ctrl + shift + alt - 7 : /opt/homebrew/bin/yabai -m window --space 7
ctrl + shift + alt - 8 : /opt/homebrew/bin/yabai -m window --space 8
ctrl + shift + alt - 9 : /opt/homebrew/bin/yabai -m window --space 9
ctrl + shift + alt - 0 : /opt/homebrew/bin/yabai -m window --space 10
ctrl + shift + alt - 0x1B : /opt/homebrew/bin/yabai -m window --space 11
ctrl + shift + alt - 0x18 : /opt/homebrew/bin/yabai -m window --space 12
