#!/usr/bin/env sh

spaces=13

# BSP tiling is the closest yabai gets to Hyprland-style automatic tiling.
/opt/homebrew/bin/yabai -m config layout bsp
/opt/homebrew/bin/yabai -m config auto_balance on
/opt/homebrew/bin/yabai -m config split_ratio 0.50
/opt/homebrew/bin/yabai -m config window_placement second_child
/opt/homebrew/bin/yabai -m config top_padding 8
/opt/homebrew/bin/yabai -m config bottom_padding 8
/opt/homebrew/bin/yabai -m config left_padding 8
/opt/homebrew/bin/yabai -m config right_padding 8
/opt/homebrew/bin/yabai -m config window_gap 8
/opt/homebrew/bin/yabai -m config insert_feedback_color 0xff255f67
/opt/homebrew/bin/yabai -m config mouse_follows_focus off
/opt/homebrew/bin/yabai -m config focus_follows_mouse off

# Float utility/system apps that work better outside the BSP tree.
/opt/homebrew/bin/yabai -m rule --add app="^System Settings$" manage=off
/opt/homebrew/bin/yabai -m rule --add app="^1Password$" manage=off
/opt/homebrew/bin/yabai -m rule --add app="^Messages$" manage=off

# Ensure a stable set of spaces exists on the primary display.
current_spaces=$(/opt/homebrew/bin/yabai -m query --spaces --display 1 | /usr/bin/grep -c '"id"')
while [ "${current_spaces}" -lt "${spaces}" ]; do
  /opt/homebrew/bin/yabai -m space --create
  current_spaces=$((current_spaces + 1))
done

# Reload the scripting addition whenever Dock restarts.
/opt/homebrew/bin/yabai -m signal --add event=dock_did_restart action="sudo /opt/homebrew/bin/yabai --load-sa"
sudo /opt/homebrew/bin/yabai --load-sa
