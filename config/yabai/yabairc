#!/usr/bin/env sh

spaces=14
machine_scope=

if [ -f "$HOME/.machine" ]; then
  machine_scope="$(/usr/bin/tr -d '[:space:]' < "$HOME/.machine")"
fi

# BSP tiling is the closest yabai gets to Hyprland-style automatic tiling.
/opt/homebrew/bin/yabai -m config layout bsp
/opt/homebrew/bin/yabai -m config auto_balance off
/opt/homebrew/bin/yabai -m config split_ratio 0.50
/opt/homebrew/bin/yabai -m config window_placement second_child
/opt/homebrew/bin/yabai -m config top_padding 8
/opt/homebrew/bin/yabai -m config bottom_padding 8
/opt/homebrew/bin/yabai -m config left_padding 8
/opt/homebrew/bin/yabai -m config right_padding 8
/opt/homebrew/bin/yabai -m config window_gap 8

/opt/homebrew/bin/yabai -m config insert_feedback_color 0xff255f67
/opt/homebrew/bin/yabai -m config mouse_follows_focus off
/opt/homebrew/bin/yabai -m config focus_follows_mouse off
/opt/homebrew/bin/yabai -m config window_opacity on
/opt/homebrew/bin/yabai -m config active_window_opacity 1.0
/opt/homebrew/bin/yabai -m config normal_window_opacity 0.83

# Float utility/system apps that work better outside the BSP tree.
/opt/homebrew/bin/yabai -m rule --remove float-settings 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-system-settings 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-1password 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-activity-monitor 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-system-information 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-photo-booth 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-obsidian 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-cleanshot 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-finder 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-ivanti 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-logi-options 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-tailscale 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-weather 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-zoom 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --remove float-settings-titles 2>/dev/null || true
/opt/homebrew/bin/yabai -m rule --add label=float-settings app="^Settings$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-system-settings app="^System Settings$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-1password app="^1Password.*$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-activity-monitor app="^Activity Monitor$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-system-information app="^System Information$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-photo-booth app="^Photo Booth$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-obsidian app="^Obsidian$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-cleanshot app="^CleanShot X$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-finder app="^Finder$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-ivanti-access app="^Ivanti Secure Access$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-ivanti app="^Ivanti Secure Access$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-ivanti-client app="^Ivanti Secure Access Client$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-logi-options app="^(logioptionsplus|Logi Options\+)$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-tailscale app="^Tailscale$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-weather app="^Weather$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-zoom app="^zoom\.us$" manage=off
/opt/homebrew/bin/yabai -m rule --add label=float-settings-titles title=".*(Settings|Preferences|Configuration|Config).*" manage=off

# Re-apply float rules to already-open utility windows when yabai reloads.
/opt/homebrew/bin/yabai -m rule --apply app="^Settings$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^System Settings$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^1Password.*$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^System Information$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Photo Booth$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Obsidian$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^CleanShot X$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Ivanti Secure Access$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Ivanti Secure Access$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Ivanti Secure Access Client$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^(logioptionsplus|Logi Options\+)$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Messages$" manage=on || true
/opt/homebrew/bin/yabai -m rule --apply app="^Morgen$" manage=on || true
/opt/homebrew/bin/yabai -m rule --apply app="^Tailscale$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply app="^Weather$" manage=off || true
/opt/homebrew/bin/yabai -m rule --apply title=".*(Settings|Preferences|Configuration|Config).*" manage=off || true

# Ensure a stable set of spaces exists on the primary display.
current_spaces=$(/opt/homebrew/bin/yabai -m query --spaces --display 1 | /usr/bin/grep -c '"id"')
while [ "${current_spaces}" -lt "${spaces}" ]; do
  /opt/homebrew/bin/yabai -m space --create
  current_spaces=$((current_spaces + 1))
done

# Reload the scripting addition whenever Dock restarts, then re-apply
# display-specific bar reservation because Dock restart clears it.
/opt/homebrew/bin/yabai -m signal --add event=dock_did_restart action="sudo /opt/homebrew/bin/yabai --load-sa; $HOME/.config/yabai/apply-display-config.sh"
sudo /opt/homebrew/bin/yabai --load-sa

# Reserve real top inset for SketchyBar after startup config settles.
$HOME/.config/yabai/apply-display-config.sh
