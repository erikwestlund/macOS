# Ansible
alias ap='ansible-playbook'
vault-edit() {
  local vault_file="$1"

  if [[ -z "$vault_file" ]]; then
    if [[ -f "./ansible/vault/secrets.yml" ]]; then
      vault_file="./ansible/vault/secrets.yml"
    elif [[ -f "./vault/secrets.yml" ]]; then
      vault_file="./vault/secrets.yml"
    else
      vault_file="$HOME/System/ansible/vault/secrets.yml"
    fi
  fi

  EDITOR=nvim ansible-vault edit "$vault_file" --vault-password-file ~/.vault_pass
}

