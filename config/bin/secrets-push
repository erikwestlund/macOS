#!/usr/bin/env bash

set -euo pipefail

CONFIG="$HOME/.config/secrets/config"
SECRETS_DIR="$HOME/.secrets"
CACHE_DIR="$HOME/.cache/secrets-encrypted"

if [[ ! -f "$CONFIG" ]]; then
    echo "Error: Config not found at $CONFIG"
    echo "Run 'ms-secrets' first to deploy credentials"
    exit 1
fi

source "$CONFIG"

if [[ -z "${B2_KEY_ID:-}" || -z "${B2_APP_KEY:-}" || -z "${B2_BUCKET:-}" || -z "${AGE_PUBLIC_KEY:-}" ]]; then
    echo "Error: Missing required config variables"
    exit 1
fi

if [[ ! -d "$SECRETS_DIR" ]]; then
    echo "Error: Secrets directory not found at $SECRETS_DIR"
    exit 1
fi

if ! command -v age >/dev/null 2>&1; then
    echo "Error: age is not installed"
    exit 1
fi

echo "Encrypting secrets..."
/bin/rm -rf "$CACHE_DIR"
mkdir -p "$CACHE_DIR"

find "$SECRETS_DIR" -type f ! -name "config" | while read -r secret_file; do
    rel_path="${secret_file#$SECRETS_DIR/}"
    if [[ "$rel_path" == ".DS_Store" ]] || [[ "$rel_path" == ssh/agent/* ]]; then
        continue
    fi
    if [[ "$rel_path" == secrets/* ]]; then
        continue
    fi
    if [[ "$rel_path" == "ssh/config" ]]; then
        continue
    fi
    if [[ "$rel_path" == backups/* ]] || [[ "$rel_path" == */backups/* ]]; then
        continue
    fi
    output_path="$CACHE_DIR/${rel_path}.age"
    mkdir -p "$(dirname "$output_path")"
    age -r "$AGE_PUBLIC_KEY" "$secret_file" > "$output_path"
    echo "  Encrypted: $rel_path"
done

echo "Syncing to B2..."
export RCLONE_CONFIG_B2_TYPE=b2
export RCLONE_CONFIG_B2_ACCOUNT="$B2_KEY_ID"
export RCLONE_CONFIG_B2_KEY="$B2_APP_KEY"

rclone sync "$CACHE_DIR/" "b2:$B2_BUCKET/secrets/" \
    --exclude "backups/**" \
    --exclude "**/backups/**" \
    --exclude "secrets/**" \
    --exclude ".DS_Store.age" \
    --exclude "ssh/agent/**" \
    --progress

echo "Done. Secrets pushed to B2."
