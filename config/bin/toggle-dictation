#!/usr/bin/env bash

set -euo pipefail

osascript <<'EOF'
tell application "System Events"
  set frontProcess to first application process whose frontmost is true

  tell frontProcess
    if not (exists menu bar item "Edit" of menu bar 1) then
      error "Frontmost app does not expose an Edit menu for Dictation."
    end if

    tell menu 1 of menu bar item "Edit" of menu bar 1
      if exists menu item "Stop Dictation" then
        click menu item "Stop Dictation"
        return
      end if

      if exists menu item "Start Dictation..." then
        click menu item "Start Dictation..."
        return
      end if

      if exists menu item "Start Dictation…" then
        click menu item "Start Dictation…"
        return
      end if
    end tell
  end tell
end tell

error "Dictation toggle menu item was not available in the frontmost app."
EOF
