#!/usr/bin/env bash

set -euo pipefail

rule_label="ghostty-btop-once"
window_width_cells=124
window_height_cells=36

display_json=$(/opt/homebrew/bin/yabai -m query --displays --display)
existing_ids=$(/opt/homebrew/bin/yabai -m query --windows | jq '[.[] | select(.app == "Ghostty") | .id]')

usable_frame=$(printf '%s' "$display_json" | jq -c '{x: (.frame.x + 8 | floor), y: (.frame.y + 40 | floor), w: (.frame.w - 16 | floor), h: (.frame.h - 48 | floor)}')

usable_x=$(printf '%s' "$usable_frame" | jq -r '.x')
usable_y=$(printf '%s' "$usable_frame" | jq -r '.y')
usable_w=$(printf '%s' "$usable_frame" | jq -r '.w')
usable_h=$(printf '%s' "$usable_frame" | jq -r '.h')

estimated_window_w=1200
estimated_window_h=800
target_x=$(( usable_x + (usable_w - estimated_window_w) / 2 ))
target_y=$(( usable_y + (usable_h - estimated_window_h) / 2 ))

/opt/homebrew/bin/yabai -m rule --add label="$rule_label" app="^Ghostty$" manage=off

"/Applications/Ghostty.app/Contents/MacOS/ghostty" \
  --window-width="$window_width_cells" \
  --window-height="$window_height_cells" \
  --window-position-x="$target_x" \
  --window-position-y="$target_y" \
  -e btop >/dev/null 2>&1 &

for _ in {1..50}; do
  new_id=$(
    /opt/homebrew/bin/yabai -m query --windows | jq -r --argjson before "$existing_ids" '
      [ .[]
        | select(.app == "Ghostty")
        | select(.id as $id | ($before | index($id) | not))
      ]
      | sort_by(.id)
      | last
      | .id // empty'
  )

  if [[ -n "$new_id" ]]; then
    /opt/homebrew/bin/yabai -m window "$new_id" --resize "abs:${estimated_window_w}:${estimated_window_h}" >/dev/null 2>&1 || true
    /opt/homebrew/bin/yabai -m window "$new_id" --move "abs:${target_x}:${target_y}" >/dev/null 2>&1 || true
    break
  fi

  sleep 0.1
done

/opt/homebrew/bin/yabai -m rule --remove "$rule_label" >/dev/null 2>&1 || true
