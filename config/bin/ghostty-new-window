#!/usr/bin/env bash

set -euo pipefail

cmd="${1:-}"

if [[ -n "$cmd" ]]; then
  osascript - "$cmd" <<'EOF'
on run argv
  set cmd to item 1 of argv
  set wasRunning to application "Ghostty" is running
  tell application "Ghostty" to activate
  delay 0.2
  if wasRunning then
    tell application "System Events"
      keystroke "n" using command down
    end tell
    delay 0.15
  end if
  tell application "System Events"
    keystroke cmd
    key code 36
  end tell
end run
EOF
else
  osascript <<'EOF'
set wasRunning to application "Ghostty" is running
tell application "Ghostty" to activate
delay 0.2
if wasRunning then
  tell application "System Events"
    keystroke "n" using command down
  end tell
end if
EOF
fi
