#!/usr/bin/env bash

set -euo pipefail

SECRETS_DIR="$HOME/.secrets"
CONFIG_DIR="$HOME/.config/secrets"
CONFIG_FILE="$CONFIG_DIR/config"

echo "System Secrets Setup"
echo "===================="
echo

if ! command -v rclone >/dev/null 2>&1; then
    echo "rclone not found. Install it first."
    exit 1
fi

mkdir -p "$SECRETS_DIR"
mkdir -p "$CONFIG_DIR"
chmod 700 "$SECRETS_DIR"
chmod 700 "$CONFIG_DIR"

if [[ -f "$CONFIG_FILE" ]]; then
    echo "Config already exists at $CONFIG_FILE"
    read -r -p "Overwrite? [y/N] " reply
    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
        echo "Aborted"
        exit 1
    fi
fi

echo "Enter your Backblaze B2 credentials:"
echo
read -r -p "Key ID: " key_id
read -r -p "Bucket name: " bucket_name
read -r -s -p "Application Key: " app_key
echo
echo

cat > "$CONFIG_FILE" <<EOF
B2_KEY_ID=$key_id
B2_APP_KEY=$app_key
B2_BUCKET=$bucket_name
EOF

chmod 600 "$CONFIG_FILE"

echo "Config saved to $CONFIG_FILE"
echo
echo "Next steps:"
echo "  secrets-pull"
echo "  ms-secrets"
