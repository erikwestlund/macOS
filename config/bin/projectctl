#!/usr/bin/env bash

set -euo pipefail

META="$HOME/.bin/project-meta"
SYSTEM_PROJECTS_DIR="$HOME/System/projects"

cmd="${1:-}"
id="${2:-}"

project_json() {
  "$META" json "$1"
}

project_value() {
  printf '%s' "$PROJECT_JSON" | /opt/homebrew/bin/jq -r "$1"
}

ensure_project_loaded() {
  PROJECT_JSON="$(project_json "$id")"
  PROJECT_NAME="$(project_value '.name')"
  PROJECT_ALIAS="$(project_value '.alias')"
  PROJECT_TYPE="$(project_value '.type')"
  PROJECT_EDITOR="$(project_value '.editor // "zed"')"
  PROJECT_DIR="$(project_value '.path')"
  PROJECT_PM_DIR="$SYSTEM_PROJECTS_DIR/$PROJECT_NAME"
  PROJECT_NODE_VERSION="$(project_value '.extras.node_version // ""')"
  PROJECT_VIEW_URL="$(project_value '.extras.view_url // ""')"
  PROJECT_DOCKER_COMPOSE="$(project_value '.docker_compose // false')"
  PROJECT_RUNTIME="$(project_value '.runtime // "container"')"
  PROJECT_ARCH_MODE="$(project_value '.architecture_mode // "default"')"
PROJECT_GITHUB_REPO="$(project_value '.github_repo // ""')"
PROJECT_REQUIRED_SECRETS="$(project_value '.required_secrets // [] | join("\n")')"
PROJECT_OPTIONAL_SECRETS="$(project_value '.optional_secrets // [] | join("\n")')"
PROJECT_BOOTSTRAP_COMMANDS="$(project_value '.bootstrap_commands // [] | join("\n")')"
}

env_value() {
  local file="$1"
  local key="$2"

  [ -f "$file" ] || return 0
  /usr/bin/perl -ne 'if (/^\Q'$key'\E=(.*)$/) { print "$1\n"; exit 0 }' "$file"
}

project_port_value() {
  local key="$1"
  project_value ".ports.${key} // empty"
}

urlencode() {
  /usr/bin/ruby -ruri -e 'print URI.encode_www_form_component(ARGV[0].to_s)' "$1"
}

tableplus_is_installed() {
  [ -d "/Applications/TablePlus.app" ]
}

tableplus_sync_project() {
  local env_file="$PROJECT_DIR/.env"
  local connection database username password service internal_port host_port scheme
  local additional_databases database_name dsn

  tableplus_is_installed || return 0
  [ -f "$env_file" ] || return 0

  connection="$(env_value "$env_file" "DB_CONNECTION")"
  database="$(env_value "$env_file" "DB_DATABASE")"
  username="$(env_value "$env_file" "DB_USERNAME")"
  password="$(env_value "$env_file" "DB_PASSWORD")"

  if [ -z "$connection" ] && [ "$PROJECT_NAME" = "naaccord-data-depot" ]; then
    connection="mariadb"
    database="$(env_value "$env_file" "DB_NAME")"
    username="$(env_value "$env_file" "DB_USER")"
    password="$(env_value "$PROJECT_DIR/.env.docker-saml" "DB_PASSWORD")"
  fi

  case "$connection" in
    pgsql|postgres|postgresql)
      scheme="postgresql"
      service="postgres"
      internal_port="5432"
      ;;
    mysql)
      scheme="mysql"
      service="mysql"
      internal_port="3306"
      ;;
    mariadb)
      scheme="mariadb"
      service="mariadb"
      internal_port="3306"
      ;;
    sqlite|'')
      return 0
      ;;
    *)
      return 0
      ;;
  esac

  [ -n "$database" ] || return 0
  [ -n "$username" ] || return 0

  host_port=""
  if [ "$PROJECT_DOCKER_COMPOSE" = "true" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
    host_port="$(cd "$PROJECT_DIR" && $(compose_cmd) port "$service" "$internal_port" 2>/dev/null | /usr/bin/perl -ne 'if (/:(\d+)$/) { print "$1\n"; exit 0 }')"
  fi

  if [ -z "$host_port" ]; then
    case "$service" in
      postgres) host_port="$(project_port_value postgres)" ;;
      mysql) host_port="$(project_port_value mysql)" ;;
      mariadb) host_port="$(project_port_value mariadb)" ;;
    esac
  fi

  [ -n "$host_port" ] || return 0

  additional_databases="$database"
  if [ "$PROJECT_NAME" = "letsrun" ]; then
    additional_databases="$(printf '%s\n' "$database"; project_value '.extras.mysql_additional_databases // [] | .[]')"
  fi

  while IFS= read -r database_name; do
    [ -n "$database_name" ] || continue
    dsn="${scheme}://$(urlencode "$username")"
    if [ -n "$password" ]; then
      dsn="${dsn}:$(urlencode "$password")"
    fi
    dsn="${dsn}@127.0.0.1:${host_port}/$(urlencode "$database_name")"
    /usr/bin/open -a TablePlus "$dsn"
  done <<< "$additional_databases"
}

ensure_path_exists() {
  if [ ! -d "$PROJECT_DIR" ]; then
    echo "Project path does not exist: $PROJECT_DIR" >&2
    exit 1
  fi
}

ensure_project_nvmrc() {
  [ -f "$PROJECT_DIR/package.json" ] || return 0
  [ -n "$PROJECT_NODE_VERSION" ] || return 0
  [ -f "$PROJECT_DIR/.nvmrc" ] && return 0
  printf '%s\n' "$PROJECT_NODE_VERSION" > "$PROJECT_DIR/.nvmrc"
}

node_shell_command() {
  local command="$1"
  printf '%s' "export NVM_DIR=\"\$HOME/.nvm\"; if [ -s \"/opt/homebrew/opt/nvm/nvm.sh\" ]; then . \"/opt/homebrew/opt/nvm/nvm.sh\"; elif [ -s \"\$HOME/.nvm/nvm.sh\" ]; then . \"\$HOME/.nvm/nvm.sh\"; fi; if command -v nvm >/dev/null 2>&1 && [ -f .nvmrc ]; then nvm install >/dev/null; nvm use >/dev/null; fi; $command"
}

run_project_node_command() {
  local command="$1"
  [ -f "$PROJECT_DIR/package.json" ] || return 0
  ensure_project_nvmrc
  (cd "$PROJECT_DIR" && bash -lc "$(node_shell_command "$command")")
}

deploy_project_secrets() {
  local src
  [ -d "$PROJECT_DIR" ] || return 0
  for src in \
    "$HOME/.secrets/$PROJECT_NAME" \
    "$HOME/.secrets/projects-env/$PROJECT_NAME" \
    "$HOME/.secrets/projects-vault/$PROJECT_NAME" \
    "$HOME/.secrets/projects-kamal/$PROJECT_NAME"
  do
    if [ -d "$src" ]; then
      /usr/bin/rsync -a --exclude='*.age' "$src/" "$PROJECT_DIR/"
    fi
  done

  find "$PROJECT_DIR" -type f -name '*.age' -delete
}

copy_required_secrets() {
  local secret src dest
  [ -d "$PROJECT_DIR" ] || return 0
  [ -n "$PROJECT_REQUIRED_SECRETS" ] || return 0
  while IFS= read -r secret; do
    [ -n "$secret" ] || continue
    src="$HOME/.secrets/$PROJECT_NAME/$secret"
    dest="$PROJECT_DIR/$secret"
    if [ ! -f "$src" ]; then
      echo "Missing required secret: $src" >&2
      exit 1
    fi
    mkdir -p "$(dirname "$dest")"
    /bin/cp "$src" "$dest"
    chmod 600 "$dest"
  done <<< "$PROJECT_REQUIRED_SECRETS"
}

copy_optional_secrets() {
  local secret src dest
  [ -d "$PROJECT_DIR" ] || return 0
  [ -n "$PROJECT_OPTIONAL_SECRETS" ] || return 0
  while IFS= read -r secret; do
    [ -n "$secret" ] || continue
    src="$HOME/.secrets/$PROJECT_NAME/$secret"
    dest="$PROJECT_DIR/$secret"
    if [ -f "$src" ]; then
      mkdir -p "$(dirname "$dest")"
      /bin/cp "$src" "$dest"
      chmod 600 "$dest"
    fi
  done <<< "$PROJECT_OPTIONAL_SECRETS"
}

ensure_docker_data_dir() {
  [ -f "$PROJECT_DIR/.env" ] || return 0
  local docker_data_dir
  docker_data_dir="$(grep '^DOCKER_DATA_DIR=' "$PROJECT_DIR/.env" | cut -d'=' -f2- || true)"
  [ -n "$docker_data_dir" ] || return 0
  if [ ! -d "$docker_data_dir" ]; then
    mkdir -p "$docker_data_dir"
  fi
}

ensure_laravel_runtime_dirs() {
  mkdir -p \
    "$PROJECT_DIR/bootstrap/cache" \
    "$PROJECT_DIR/storage/logs" \
    "$PROJECT_DIR/storage/framework/cache/data" \
    "$PROJECT_DIR/storage/framework/sessions" \
    "$PROJECT_DIR/storage/framework/views"
}

set_env_value() {
  local file="$1"
  local key="$2"
  local value="$3"

  [ -f "$file" ] || return 0

  if /usr/bin/grep -q "^${key}=" "$file"; then
    /usr/bin/perl -0pi -e "s/^\Q${key}\E=.*/${key}=${value}/m" "$file"
  else
    printf '%s=%s\n' "$key" "$value" >> "$file"
  fi
}

normalize_letsrun_env() {
  local env_file="$PROJECT_DIR/.env"

  [ "$PROJECT_NAME" = "letsrun" ] || return 0
  [ -f "$env_file" ] || return 0

  set_env_value "$env_file" "DB_HOST_READ" "mysql"
  set_env_value "$env_file" "DB_HOST_WRITE" "mysql"
  set_env_value "$env_file" "DB_HOST_READ_REPLICA" "mysql"
  set_env_value "$env_file" "DB_USERNAME" "letsrun"
  set_env_value "$env_file" "DB_PASSWORD" "letsrun-dev-secret"
  set_env_value "$env_file" "DB_PASSWORD_READ" "letsrun-dev-secret"
  set_env_value "$env_file" "DB_PASSWORD_WRITE" "letsrun-dev-secret"
  set_env_value "$env_file" "DB_PASSWORD_READ_REPLICA" "letsrun-dev-secret"
  set_env_value "$env_file" "LRC_LEGACY_DB_HOST" "mysql"
  set_env_value "$env_file" "LRC_LEGACY_DB_USERNAME" "letsrun"
  set_env_value "$env_file" "LRC_LEGACY_DB_PASSWORD" "letsrun-dev-secret"
  set_env_value "$env_file" "LRC_WORDPRESS_DB_HOST" "mysql"
  set_env_value "$env_file" "LRC_WORDPRESS_DB_USERNAME" "letsrun"
  set_env_value "$env_file" "LRC_WORDPRESS_DB_PASSWORD" "letsrun-dev-secret"
  set_env_value "$env_file" "REDIS_HOST" "redis"
  set_env_value "$env_file" "CACHE_REDIS_HOST" "redis"
  set_env_value "$env_file" "CACHE_REDIS_HOST_PRIMARY" "redis"
  set_env_value "$env_file" "CACHE_REDIS_HOST_SECONDARY" "redis"
  set_env_value "$env_file" "CACHE_REDIS_DB" "1"
  set_env_value "$env_file" "SESSION_REDIS_HOST" "redis"
  set_env_value "$env_file" "SESSION_REDIS_DB" "2"
  set_env_value "$env_file" "QUEUE_REDIS_HOST" "redis"
  set_env_value "$env_file" "QUEUE_REDIS_DB" "3"
  set_env_value "$env_file" "MAIL_HOST" "mailpit"
  set_env_value "$env_file" "MAIL_PORT" "1025"
}

generate_naaccord_local_override() {
  cat > "$PROJECT_DIR/docker-compose.local.yml" <<'EOF'
services:
  mock-idp:
    build:
      context: .
      dockerfile: deploy/containers/mock-idp/Dockerfile
    image: ghcr.io/jhbiostatcenter/naaccord/mock-idp:latest

  web:
    build:
      context: .
      dockerfile: deploy/containers/web/Dockerfile
    image: ghcr.io/jhbiostatcenter/naaccord/web:latest

  services:
    build:
      context: .
      dockerfile: deploy/containers/services/Dockerfile
    image: ghcr.io/jhbiostatcenter/naaccord/services:latest

  celery:
    image: ghcr.io/jhbiostatcenter/naaccord/services:latest

  flower:
    image: ghcr.io/jhbiostatcenter/naaccord/services:latest
EOF
}

compose_cmd() {
  if [ "$PROJECT_NAME" = "better-shoes" ] && [ -f "$PROJECT_DIR/docker-compose.local.generated.yml" ]; then
    echo "docker compose -f docker-compose.local.generated.yml"
  elif [ "$PROJECT_NAME" = "naaccord-data-depot" ] && [ -f "$PROJECT_DIR/docker-compose.local.yml" ]; then
    echo "docker compose -f docker-compose.yml -f docker-compose.local.yml"
  else
    echo "docker compose"
  fi
}

ensure_shared_mailpit() {
  if ! docker network inspect mailpit_default >/dev/null 2>&1; then
    docker network create mailpit_default >/dev/null 2>&1 || true
  fi

  if ! docker ps --format '{{.Names}}' | grep -q '^mailpit$'; then
    docker rm -f mailpit >/dev/null 2>&1 || true
    docker run -d --name mailpit --network mailpit_default -p 127.0.0.1:1025:1025 -p 127.0.0.1:8025:8025 axllent/mailpit:latest >/dev/null 2>&1 || true
  fi
}

generate_better_shoes_compose() {
  local reference_project="$HOME/Projects/pequod"

  cat > "$PROJECT_DIR/docker-compose.local.generated.yml" <<'EOF'
services:
  php:
    build:
      context: .
      dockerfile: docker/php/Dockerfile
    container_name: better-shoes-php
    restart: on-failure
    working_dir: /var/www/html
    volumes:
      - ./:/var/www/html
      - ./docker/php/php.ini:/usr/local/etc/php/conf.d/custom.ini:ro
      - /var/run/docker.sock:/var/run/docker.sock
    networks:
      - better-shoes-network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      meilisearch:
        condition: service_started
    environment:
      - PHP_MEMORY_LIMIT=512M

  nginx:
    image: nginx:alpine
    container_name: better-shoes-nginx
    restart: on-failure
    ports:
      - "127.0.0.1:8020:80"
    volumes:
      - ./:/var/www/html:ro
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - better-shoes-network
    depends_on:
      - php

  postgres:
    image: postgres:17-alpine
    container_name: better-shoes-postgres
    restart: on-failure
    environment:
      POSTGRES_DB: better_shoes
      POSTGRES_USER: better_shoes
      POSTGRES_PASSWORD: better-shoes-dev-secret
    volumes:
      - ${DOCKER_DATA_DIR:-./storage/docker}/postgres:/var/lib/postgresql/data
      - ./storage/app/dumps:/dumps
    ports:
      - "127.0.0.1:5433:5432"
    networks:
      - better-shoes-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U better_shoes -d better_shoes"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: better-shoes-redis
    restart: on-failure
    volumes:
      - ${DOCKER_DATA_DIR:-./storage/docker}/redis:/data
    ports:
      - "127.0.0.1:6380:6379"
    networks:
      - better-shoes-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  meilisearch:
    image: getmeili/meilisearch:latest
    container_name: better-shoes-meilisearch
    restart: on-failure
    environment:
      MEILI_ENV: development
      MEILI_MASTER_KEY: better-shoes-dev-secret
      MEILI_NO_ANALYTICS: true
    volumes:
      - ${DOCKER_DATA_DIR:-./storage/docker}/meilisearch:/meili_data
    ports:
      - "127.0.0.1:7700:7700"
    networks:
      - better-shoes-network

  mailpit:
    image: axllent/mailpit:latest
    container_name: better-shoes-mailpit
    restart: on-failure
    ports:
      - "127.0.0.1:1026:1025"
      - "127.0.0.1:8026:8025"
    networks:
      - better-shoes-network

  r-executor:
    image: ghcr.io/letsrun/better-shoes-r-executor:latest
    container_name: better-shoes-r-executor
    platform: linux/amd64
    volumes:
      - .:/app:rw
      - ./.env:/app/.env:ro
    networks:
      - better-shoes-network
    environment:
      - DOCKER_CONTAINER=true
      - DB_HOST=postgres
      - DB_DATABASE=better_shoes
      - DB_USERNAME=better_shoes
      - DB_PASSWORD=better-shoes-dev-secret
      - DB_PORT=5432
    restart: on-failure
    depends_on:
      postgres:
        condition: service_healthy
    command: tail -f /dev/null

networks:
  better-shoes-network:
    driver: bridge
EOF

  if [ -d "$reference_project/docker/php" ]; then
    mkdir -p "$PROJECT_DIR/docker/php"
    cp "$reference_project/docker/php/Dockerfile" "$PROJECT_DIR/docker/php/" 2>/dev/null || true
    cp "$reference_project/docker/php/php.ini" "$PROJECT_DIR/docker/php/" 2>/dev/null || true
  fi

  if [ -d "$reference_project/docker/nginx" ]; then
    mkdir -p "$PROJECT_DIR/docker/nginx"
    cp "$reference_project/docker/nginx/default.conf" "$PROJECT_DIR/docker/nginx/" 2>/dev/null || true
  fi

  mkdir -p "$PROJECT_DIR/storage/app/media"
  ln -sf "$PROJECT_DIR/storage/app/media" "$PROJECT_DIR/public/media"
}

bootstrap_laravel() {
  ensure_laravel_runtime_dirs
  ensure_docker_data_dir
  ensure_project_nvmrc
  if [ "$PROJECT_NAME" = "better-shoes" ]; then
    generate_better_shoes_compose
    if [ -x "$HOME/.bin/ghcr-login" ]; then
      "$HOME/.bin/ghcr-login" >/dev/null 2>&1 || true
    fi
  fi
  if [ "$PROJECT_NAME" = "wordle-group" ]; then
    ensure_shared_mailpit
  fi
  if [ "$PROJECT_RUNTIME" != "herd" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
    (cd "$PROJECT_DIR" && $(compose_cmd) build)
  fi
  if [ "$PROJECT_RUNTIME" != "herd" ] && [ -f "$PROJECT_DIR/composer.json" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
    (cd "$PROJECT_DIR" && $(compose_cmd) up -d)
    (cd "$PROJECT_DIR" && $(compose_cmd) exec -T php composer install --no-interaction --prefer-dist --optimize-autoloader)
  fi
  run_project_node_command "npm install"
}

bootstrap_python() {
  ensure_docker_data_dir
  ensure_project_nvmrc
  if [ "$PROJECT_NAME" = "naaccord-data-depot" ] && [ "$PROJECT_ARCH_MODE" = "local-build" ]; then
    generate_naaccord_local_override
  fi
  if [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
    (cd "$PROJECT_DIR" && $(compose_cmd) build)
  fi
  run_project_node_command "npm install"
}

bootstrap_rstats() {
  ensure_project_nvmrc
  if [ -f "$PROJECT_DIR/DESCRIPTION" ]; then
    (cd "$PROJECT_DIR" && Rscript -e "dir.create(Sys.getenv('R_LIBS_USER'), recursive = TRUE, showWarnings = FALSE); for (pkg in c('devtools','remotes')) { if (!requireNamespace(pkg, quietly = TRUE)) install.packages(pkg, repos = 'https://cloud.r-project.org', lib = Sys.getenv('R_LIBS_USER')) }; devtools::install_deps()") || true
    if [ "$PROJECT_NAME" = "framework" ]; then
      (cd "$PROJECT_DIR" && Rscript -e "remotes::install_git('https://github.com/table1/framework')") || true
    fi
  fi
  if [ -f "$PROJECT_DIR/renv.lock" ]; then
    (cd "$PROJECT_DIR" && Rscript -e 'if (!requireNamespace("renv", quietly = TRUE)) install.packages("renv", repos = "https://cloud.r-project.org"); renv::restore(prompt = FALSE)') || true
  fi
  run_project_node_command "npm install"
}

run_bootstrap_commands() {
  [ -n "$PROJECT_BOOTSTRAP_COMMANDS" ] || return 0
  while IFS= read -r command; do
    [ -n "$command" ] || continue
    (cd "$PROJECT_DIR" && bash -lc "$command")
  done <<< "$PROJECT_BOOTSTRAP_COMMANDS"
}

setup_project() {
  clone_if_needed
  ensure_path_exists
  prefer_main_branch
  mkdir -p "$PROJECT_PM_DIR"
  deploy_project_secrets
  copy_required_secrets
  copy_optional_secrets
  normalize_letsrun_env
  ensure_project_nvmrc
  ensure_docker_data_dir

  if [ "$PROJECT_TYPE" = "laravel" ]; then
    ensure_laravel_runtime_dirs
    if [ "$PROJECT_NAME" = "wordle-group" ] && [ -f "$PROJECT_DIR/.env.docker" ]; then
      cp "$PROJECT_DIR/.env.docker" "$PROJECT_DIR/.env"
    fi
  fi

  if [ "$PROJECT_TYPE" = "python" ]; then
    if [ -n "$PROJECT_BOOTSTRAP_COMMANDS" ]; then
      while IFS= read -r command; do
        [ -n "$command" ] || continue
        case "$command" in
          *"docker compose"*|*"docker exec"*) ;;
          *) (cd "$PROJECT_DIR" && bash -lc "$command") ;;
        esac
      done <<< "$PROJECT_BOOTSTRAP_COMMANDS"
    fi
  fi
}

ensure_tmux_session() {
  if tmux has-session -t "$PROJECT_ALIAS" 2>/dev/null; then
    return 0
  fi

  mkdir -p "$PROJECT_PM_DIR"

  tmux new-session -d -s "$PROJECT_ALIAS" -n zsh -c "$PROJECT_DIR"
  tmux new-window -t "$PROJECT_ALIAS":2 -n opencode-1 -c "$PROJECT_DIR"
  tmux send-keys -t "$PROJECT_ALIAS":2 "tmux-opencode"
  tmux new-window -t "$PROJECT_ALIAS":3 -n opencode-2 -c "$PROJECT_DIR"
  tmux send-keys -t "$PROJECT_ALIAS":3 "tmux-opencode"
  tmux new-window -t "$PROJECT_ALIAS":4 -n claude-1 -c "$PROJECT_DIR"
  tmux send-keys -t "$PROJECT_ALIAS":4 "tmux-claude"
  tmux new-window -t "$PROJECT_ALIAS":5 -n claude-2 -c "$PROJECT_DIR"
  tmux send-keys -t "$PROJECT_ALIAS":5 "tmux-claude"

  case "$PROJECT_TYPE" in
    laravel)
      tmux new-window -t "$PROJECT_ALIAS":6 -n docker -c "$PROJECT_DIR"
      tmux send-keys -t "$PROJECT_ALIAS":6 "docker compose up" C-m
      tmux new-window -t "$PROJECT_ALIAS":7 -n npm -c "$PROJECT_DIR"
      tmux send-keys -t "$PROJECT_ALIAS":7 "$(node_shell_command "[ -f package.json ] && npm run dev")" C-m
      tmux new-window -t "$PROJECT_ALIAS":8 -n artisan -c "$PROJECT_DIR"
      tmux new-window -t "$PROJECT_ALIAS":9 -n project -c "$PROJECT_PM_DIR"
      ;;
    python)
      tmux new-window -t "$PROJECT_ALIAS":6 -n python -c "$PROJECT_DIR"
      tmux send-keys -t "$PROJECT_ALIAS":6 "[ -d .venv ] && source .venv/bin/activate; python3" C-m
      tmux new-window -t "$PROJECT_ALIAS":7 -n project -c "$PROJECT_PM_DIR"
      ;;
    rstats)
      tmux new-window -t "$PROJECT_ALIAS":6 -n R -c "$PROJECT_DIR"
      tmux send-keys -t "$PROJECT_ALIAS":6 "R" C-m
      tmux new-window -t "$PROJECT_ALIAS":7 -n python -c "$PROJECT_DIR"
      tmux send-keys -t "$PROJECT_ALIAS":7 "[ -d .venv ] && source .venv/bin/activate; python3" C-m
      tmux new-window -t "$PROJECT_ALIAS":8 -n project -c "$PROJECT_PM_DIR"
      ;;
    *)
      tmux new-window -t "$PROJECT_ALIAS":6 -n project -c "$PROJECT_PM_DIR"
      ;;
  esac

  tmux select-window -t "$PROJECT_ALIAS":1
}

clone_if_needed() {
  if [ -d "$PROJECT_DIR" ]; then
    return 0
  fi
  if [ -z "$PROJECT_GITHUB_REPO" ]; then
    return 0
  fi
  mkdir -p "$(dirname "$PROJECT_DIR")"
  case "$PROJECT_GITHUB_REPO" in
    http*|git@*) git clone "$PROJECT_GITHUB_REPO" "$PROJECT_DIR" ;;
    *) git clone "git@github.com:$PROJECT_GITHUB_REPO.git" "$PROJECT_DIR" ;;
  esac
}

prefer_main_branch() {
  [ -d "$PROJECT_DIR/.git" ] || return 0
  if git -C "$PROJECT_DIR" ls-remote --exit-code --heads origin main >/dev/null 2>&1; then
    current_branch="$(git -C "$PROJECT_DIR" branch --show-current || true)"
    if [ "$current_branch" != "main" ]; then
      if git -C "$PROJECT_DIR" show-ref --verify --quiet refs/heads/main; then
        git -C "$PROJECT_DIR" checkout main
      else
        git -C "$PROJECT_DIR" checkout -b main --track origin/main
      fi
    fi
    git -C "$PROJECT_DIR" branch --set-upstream-to=origin/main main >/dev/null 2>&1 || true
  fi
}

case "$cmd" in
  bootstrap)
    ensure_project_loaded
    setup_project
    case "$PROJECT_TYPE" in
      laravel) bootstrap_laravel ;;
      python) bootstrap_python ;;
      rstats) bootstrap_rstats ;;
    esac
    if [ "$PROJECT_NAME" = "naaccord-data-depot" ]; then
      (cd "$PROJECT_DIR" && $(compose_cmd) up -d)
      docker exec naaccord-test-web python manage.py migrate --noinput
      docker exec naaccord-test-web python manage.py seed_init
      docker exec naaccord-test-web python manage.py load_test_users
    fi
    run_bootstrap_commands
    tableplus_sync_project
    if [ "$PROJECT_DOCKER_COMPOSE" = "true" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
      true
    fi
    ;;
  setup)
    ensure_project_loaded
    setup_project
    ;;
  launch)
    ensure_project_loaded
    ensure_path_exists
    mkdir -p "$PROJECT_PM_DIR"
    deploy_project_secrets
    if [ "$PROJECT_DOCKER_COMPOSE" = "true" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
      (cd "$PROJECT_DIR" && $(compose_cmd) up -d)
    fi
    ensure_tmux_session
    ;;
  kill)
    ensure_project_loaded
    if [ "$PROJECT_DOCKER_COMPOSE" = "true" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ]; then
      (cd "$PROJECT_DIR" && $(compose_cmd) down)
    fi
    tmux kill-session -t "$PROJECT_ALIAS" 2>/dev/null || true
    ;;
  tmux)
    ensure_project_loaded
    ensure_path_exists
    ensure_tmux_session
    exec tmux attach-session -t "$PROJECT_ALIAS"
    ;;
  term)
    ensure_project_loaded
    ensure_path_exists
    "$HOME/.bin/ghostty-new-window" "cd '$PROJECT_DIR' && $HOME/.bin/projectctl tmux $PROJECT_ALIAS"
    ;;
  zed)
    ensure_project_loaded
    ensure_path_exists
    /usr/bin/open -a "Zed" "$PROJECT_DIR"
    ;;
  positron)
    ensure_project_loaded
    ensure_path_exists
    /usr/bin/open -a "Positron" "$PROJECT_DIR"
    ;;
  view)
    ensure_project_loaded
    [ -n "$PROJECT_VIEW_URL" ] || exit 0
    /usr/bin/open "$PROJECT_VIEW_URL"
    ;;
  up)
    ensure_project_loaded
    ensure_path_exists
    [ "$PROJECT_DOCKER_COMPOSE" = "true" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ] && (cd "$PROJECT_DIR" && $(compose_cmd) up -d)
    ;;
  down)
    ensure_project_loaded
    ensure_path_exists
    [ "$PROJECT_DOCKER_COMPOSE" = "true" ] && [ -f "$PROJECT_DIR/docker-compose.yml" ] && (cd "$PROJECT_DIR" && $(compose_cmd) down)
    ;;
  deploy-secrets)
    if [ "${id:-}" = "--all" ] || [ -z "${id:-}" ]; then
      while IFS= read -r alias_name; do
        [ -n "$alias_name" ] || continue
        id="$alias_name"
        ensure_project_loaded
        deploy_project_secrets
      done < <("$META" aliases | /usr/bin/grep "alias b" | /usr/bin/sed -E "s/alias b([a-zA-Z0-9_-]+)=.*/\1/")
    else
      ensure_project_loaded
      deploy_project_secrets
    fi
    ;;
  tableplus)
    ensure_project_loaded
    setup_project
    tableplus_sync_project
    ;;
  *)
    echo "usage: projectctl <setup|bootstrap|launch|kill|tmux|term|zed|positron|view|up|down|deploy-secrets|tableplus> <alias>" >&2
    exit 1
    ;;
esac
