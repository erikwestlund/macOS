#!/usr/bin/env bash

set -euo pipefail

CONFIG="$HOME/.config/secrets/config"
SECRETS_DIR="$HOME/.secrets"
CACHE_DIR="$HOME/.cache/secrets-encrypted"

if [[ ! -f "$CONFIG" ]]; then
    echo "Error: Config not found at $CONFIG"
    echo "Run 'ms-secrets' first to deploy credentials"
    exit 1
fi

source "$CONFIG"

if [[ -z "${B2_KEY_ID:-}" || -z "${B2_APP_KEY:-}" || -z "${B2_BUCKET:-}" || -z "${AGE_SECRET_KEY:-}" ]]; then
    echo "Error: Missing required config variables"
    exit 1
fi

if ! command -v age >/dev/null 2>&1; then
    echo "Error: age is not installed"
    exit 1
fi

echo "Syncing encrypted secrets from B2..."
mkdir -p "$CACHE_DIR"

export RCLONE_CONFIG_B2_TYPE=b2
export RCLONE_CONFIG_B2_ACCOUNT="$B2_KEY_ID"
export RCLONE_CONFIG_B2_KEY="$B2_APP_KEY"

rclone sync "b2:$B2_BUCKET/secrets/" "$CACHE_DIR/" \
    --update \
    --exclude "backups/**" \
    --exclude "**/backups/**" \
    --exclude "secrets/**" \
    --exclude ".DS_Store.age" \
    --exclude "ssh/agent/**" \
    --progress

echo "Decrypting secrets..."
mkdir -p "$SECRETS_DIR"
chmod 700 "$SECRETS_DIR"

AGE_KEY_FILE=$(mktemp)
echo "$AGE_SECRET_KEY" > "$AGE_KEY_FILE"
chmod 600 "$AGE_KEY_FILE"
trap 'rm -f "$AGE_KEY_FILE"' EXIT

find "$CACHE_DIR" -name "*.age" -type f ! -name ".DS_Store.age" | while read -r encrypted_file; do
    rel_path="${encrypted_file#$CACHE_DIR/}"
    if [[ "$rel_path" == "config.age" ]]; then
        continue
    fi
    if [[ "$rel_path" == secrets/* ]]; then
        continue
    fi
    if [[ "$rel_path" == "ssh/config.age" ]]; then
        continue
    fi
    if [[ "$rel_path" == backups/* ]] || [[ "$rel_path" == */backups/* ]]; then
        continue
    fi
    output_path="$SECRETS_DIR/${rel_path%.age}"
    mkdir -p "$(dirname "$output_path")"
    age -d -i "$AGE_KEY_FILE" "$encrypted_file" > "$output_path"
    chmod 600 "$output_path"
    echo "  Decrypted: ${rel_path%.age}"
done

if [[ -d "$SECRETS_DIR/ssh" ]]; then
    chmod 700 "$SECRETS_DIR/ssh"
    find "$SECRETS_DIR/ssh" -type f -name "*.pub" -exec chmod 644 {} \;
    find "$SECRETS_DIR/ssh" -type f ! -name "*.pub" ! -name "known_hosts*" ! -name "authorized_keys" ! -name "config" -exec chmod 600 {} \;
    [[ -f "$SECRETS_DIR/ssh/config" ]] && chmod 644 "$SECRETS_DIR/ssh/config"
    [[ -f "$SECRETS_DIR/ssh/known_hosts" ]] && chmod 644 "$SECRETS_DIR/ssh/known_hosts"
    [[ -f "$SECRETS_DIR/ssh/authorized_keys" ]] && chmod 600 "$SECRETS_DIR/ssh/authorized_keys"
fi

if [[ -d "$SECRETS_DIR/aws" ]]; then
    chmod 700 "$SECRETS_DIR/aws"
    find "$SECRETS_DIR/aws" -type f -exec chmod 600 {} \;
fi

if [[ -d "$SECRETS_DIR/rclone" ]]; then
    chmod 700 "$SECRETS_DIR/rclone"
    find "$SECRETS_DIR/rclone" -type f -exec chmod 600 {} \;
fi

# Remove any leftover encrypted payloads from the decrypted secrets tree.
find "$SECRETS_DIR" -type f -name "*.age" -delete

if [[ -x "$HOME/.bin/projectctl" ]]; then
    "$HOME/.bin/projectctl" deploy-secrets --all || true
fi

echo "Done. Secrets available at $SECRETS_DIR"
