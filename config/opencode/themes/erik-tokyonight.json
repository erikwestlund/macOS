{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "none",
    "bg_panel": "#16161e",
    "bg_element": "#1f2335",
    "bg_menu": "#1a1b26",
    "fg": "#c0caf5",
    "fg_muted": "#7f89b0",
    "blue": "#7aa2f7",
    "cyan": "#7dcfff",
    "green": "#9ece6a",
    "orange": "#ff9e64",
    "red": "#f7768e",
    "yellow": "#e0af68",
    "accent": "#646b97",
    "accent_soft": "#7a82b2",
    "border": "#2a2f45",
    "border_active": "#646b97",
    "border_subtle": "#24283b",
    "diff_add_bg": "#20303b",
    "diff_remove_bg": "#3b202c",
    "diff_context_bg": "#1a1b26"
  },
  "theme": {
    "primary": {
      "dark": "accent",
      "light": "accent"
    },
    "secondary": {
      "dark": "accent_soft",
      "light": "accent_soft"
    },
    "accent": {
      "dark": "accent",
      "light": "accent"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "fg",
      "light": "fg"
    },
    "textMuted": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "background": {
      "dark": "bg",
      "light": "bg"
    },
    "backgroundPanel": {
      "dark": "bg_panel",
      "light": "bg_panel"
    },
    "backgroundElement": {
      "dark": "bg_element",
      "light": "bg_element"
    },
    "backgroundMenu": {
      "dark": "bg_menu",
      "light": "bg_menu"
    },
    "border": {
      "dark": "border",
      "light": "border"
    },
    "borderActive": {
      "dark": "border_active",
      "light": "border_active"
    },
    "borderSubtle": {
      "dark": "border_subtle",
      "light": "border_subtle"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffHunkHeader": {
      "dark": "accent_soft",
      "light": "accent_soft"
    },
    "diffHighlightAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "diff_add_bg",
      "light": "diff_add_bg"
    },
    "diffRemovedBg": {
      "dark": "diff_remove_bg",
      "light": "diff_remove_bg"
    },
    "diffContextBg": {
      "dark": "diff_context_bg",
      "light": "diff_context_bg"
    },
    "diffLineNumber": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffAddedLineNumberBg": {
      "dark": "diff_add_bg",
      "light": "diff_add_bg"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diff_remove_bg",
      "light": "diff_remove_bg"
    },
    "markdownText": {
      "dark": "fg",
      "light": "fg"
    },
    "markdownHeading": {
      "dark": "accent_soft",
      "light": "accent_soft"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCode": {
      "dark": "green",
      "light": "green"
    },
    "markdownBlockQuote": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownEmph": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownStrong": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownHorizontalRule": {
      "dark": "border_subtle",
      "light": "border_subtle"
    },
    "markdownListItem": {
      "dark": "accent_soft",
      "light": "accent_soft"
    },
    "markdownListEnumeration": {
      "dark": "accent",
      "light": "accent"
    },
    "markdownImage": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownImageText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxComment": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "syntaxKeyword": {
      "dark": "accent_soft",
      "light": "accent_soft"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxType": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxOperator": {
      "dark": "accent",
      "light": "accent"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "fg"
    }
  }
}
