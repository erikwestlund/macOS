[user]
	name = Erik Westlund
	email = edbwestlund@gmail.com

[init]
	defaultBranch = main

[core]
	editor = /opt/homebrew/bin/nvim
	excludesfile = ~/.gitignore_global
	autocrlf = input
	ignorecase = false

[color]
	ui = auto
	diff = auto
	status = auto
	branch = auto

[pull]
	rebase = false

[push]
	default = current

[merge]
	ff = only

[alias]
	s = status
	a = add
	c = commit -v
	cm = commit -m
	ca = commit -a -v
	cam = commit -a -m
	amend = commit --amend
	b = branch
	co = checkout
	cob = checkout -b
	d = diff
	dc = diff --cached
	ds = diff --stat
	p = push
	l = pull
	rao = !f() { git remote add origin git@github.com:$1.git; }; f
	log = log --oneline --decorate --graph
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	undo = reset HEAD~1 --mixed
	unstage = reset HEAD --
	last = log -1 HEAD
	aliases = config --get-regexp alias

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[url "https://github.com/OHDSI-JHU/"]
	insteadOf = https://github.com/OHDSI-JHU/

[url "git@github.com:"]
	insteadOf = https://github.com/

[credential]
	helper = cache
	useHttpPath = true

[credential "https://github.com"]
	helper = store --file ~/.git-credentials-ohdsi-jhu
	useHttpPath = false
